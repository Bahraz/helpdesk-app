<% 
  // 1. Zmienne wyglądu karty
  let cardStyle = '';
  let titleClass = 'ticket-title'; // Domyślna klasa
  
  if (type === 'active') {
    cardStyle = 'border-color: var(--primary-glow);';
  } else if (type === 'closed') {
    cardStyle = 'opacity: 0.8;';
    titleClass += ' is-closed'; // Dopisujemy klasę do tytułu dla zamkniętych zgłoszeń
  }
  
  // 2. Obsługa priorytetów
  const p = (ticket.priority || ticket.priorytet || '').toLowerCase();
  let priorityClass = 'priority-low';
  if (['high', 'wysoki', 'critical', 'krytyczny'].includes(p)) priorityClass = 'priority-high';
  else if (['medium', 'średni'].includes(p)) priorityClass = 'priority-medium';

  const displayPriority = ticket.priorytet || (p === 'high' ? 'Wysoki' : p === 'medium' ? 'Średni' : p === 'critical' ? 'Krytyczny' : 'Niski');
  const displayStatus = ticket.status_label || ticket.status;
%>

<div class="ticket-card" style="<%= cardStyle %>">
  <div class="ticket-meta">
    <span class="ticket-id">#T-<%= ticket.id %></span>
    <span class="ticket-time"><i class="fa-regular fa-clock"></i> <%= ticket.czas_zalozenia || new Date(ticket.created_at).toLocaleDateString('pl-PL') %></span>
  </div>
  
  <div class="<%= titleClass %>">
    <%= ticket.title || ticket.tytul %>
  </div>
  
  <div class="ticket-desc"><%= ticket.description || ticket.opis %></div>
  
  <div style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1rem;">
    <i class="fa-solid fa-user"></i> <%= ticket.tworca_nazwa || (user.firstName + ' ' + user.lastName) %>
  </div>
  
  <div class="ticket-footer" style="margin-top: auto;">
    <% if (type === 'pending') { %>
      <span class="priority-badge <%= priorityClass %>"><i class="fa-solid fa-flag"></i> <%= displayPriority %></span>
      <a href="/tickets/details/<%= ticket.id %>" class="btn btn-outline" style="padding: 0.4rem 1rem; font-size: 0.85rem;">Szczegóły</a>
    <% } else if (type === 'active' || type === 'user-active') { %>
      <span class="status-badge"><i class="fa-solid fa-spinner fa-spin"></i> <%= displayStatus %></span>
      <a href="/tickets/details/<%= ticket.id %>" class="btn btn-primary" style="padding: 0.4rem 1rem; font-size: 0.85rem;">Szczegóły</a>
    <% } else if (type === 'closed') { %>
      <span class="badge" style="background: rgba(34, 197, 94, 0.15); color: #22c55e; margin: 0; padding: 0.5rem 1rem;"><i class="fa-solid fa-check"></i> <%= displayStatus %></span>
      <a href="/tickets/details/<%= ticket.id %>" class="btn btn-outline" style="padding: 0.4rem 1rem; font-size: 0.85rem;">Szczegóły</a>
    <% } %>
  </div>
</div>