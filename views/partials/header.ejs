<header class="navbar">
    <a href="/" class="logo">
      <i class="fa-solid fa-layer-group"></i> Help<span>Desk</span>
    </a>
    <nav class="nav-links">
      <% if (typeof user !== 'undefined' && user) { %>
        <% if (user.role === 'admin') { %>
          <a href="/tickets?status=new">Oczekujące</a>
          <a href="/tickets?status=in_progress">Przyjęte</a>
          <a href="/tickets?status=closed">Zamknięte</a>
          <a href="/users">Użytkownicy</a>
          <a href="/auth/logout" class="btn btn-outline">Wyloguj</a>
        <% } else if (user.role === 'requestor') { %>
          <a href="/tickets/create">Utwórz zgłoszenie</a>
          <a href="/tickets">Moje zgłoszenia</a>
          <a href="/users/profile">Mój profil</a>
          <a href="/auth/logout" class="btn btn-outline">Wyloguj</a>
        <% } %>
      <% } else { %>
        <a href="#function">Jak to działa</a>
        <a href="#why-us">Dlaczego my?</a>
        <a href="#offer">Oferta</a>
        <a href="#join-us">Dołącz do nas</a>
        <a href="/auth/login" class="btn btn-outline"><i class="fa-solid fa-arrow-right-to-bracket" style="margin-right: 6px;"></i>Zaloguj się</a>
      <% } %>
    </nav>
  </header>
