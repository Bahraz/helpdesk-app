<main class="page-container">
  <div class="back-link">
    <a href="/"
      ><i class="fa-solid fa-arrow-left"></i> Powrót do listy</a
    >
  </div>

  <div class="auth-section pt-2">
    <div class="auth-card card-wider text-left">
      <h2>Utwórz <span class="highlight">nowe zgłoszenie</span></h2>
      <p>
        Opisz swój problem techniczny, a nasi specjaliści zajmą się nim
        niezwłocznie.
      </p>

      <% if (locals.error) { %>
        <div class="alert"><i class="fa-solid fa-triangle-exclamation"></i> <%= locals.error %></div>
      <% } %>

      <% if (locals.success) { %>
        <div class="alert alert-success">
          <i class="fa-solid fa-check"></i> <%= locals.success %>
        </div>
      <% } %>

      <form action="/tickets" method="POST">
        <div class="form-group">
          <label for="title">Temat zgłoszenia</label>
          <input
            type="text"
            id="title"
            name="title"
            class="form-control"
            placeholder="Krótki tytuł (np. Problem z dostępem do folderu)"
            required
            value="<%= locals.old ? old.title : '' %>"
          />
        </div>

        <div class="form-group">
          <label for="description">Opis problemu</label>
          <textarea
            id="description"
            name="description"
            class="form-control textarea-large"
            placeholder="Opisz dokładnie, co się stało..."
            required
          ><%= locals.old ? old.description : '' %></textarea>
        </div>

        <div class="form-group form-group-narrow">
          <label for="priority">Priorytet zgłoszenia</label>
          <select id="priority" name="priority" class="form-control">
            <option value="low" <%= (locals.old && old.priority === 'low') ? 'selected' : '' %>>Niski</option>
            <option value="medium" <%= (!locals.old || old.priority === 'medium') ? 'selected' : '' %>>Średni (Normalny)</option>
            <option value="high" <%= (locals.old && old.priority === 'high') ? 'selected' : '' %>>Wysoki</option>
          </select>
        </div>

        <div class="flex-gap mt-2">
          <button type="submit" class="btn btn-primary">
            Wyślij zgłoszenie
          </button>
          <a href="/" class="btn btn-secondary">Anuluj</a>
        </div>
      </form>
    </div>
  </div>
</main>
