<main class="page-container">
    <div class="back-link">
    <a href="/"><i class="fa-solid fa-arrow-left"></i> Powrót</a>
  </div>
  <div class="flex-center pt-2">
    <div class="auth-card card-wide text-left">
      <h2>Mój <span class="highlight">Profil</span></h2>
      <p>Zaktualizuj swoje dane kontaktowe lub zmień hasło dostępu.</p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert"><i class="fa-solid fa-triangle-exclamation"></i> <%= error %></div>
      <% } %>

      <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success"><i class="fa-solid fa-check"></i> <%= success %></div>
      <% } %>

      <form action="/users/profile" method="POST" class="mt-2">
        <h4 class="dashboard-section-title">Dane kontaktowe</h4>
        
        <div class="form-group">
          <label>Imię i Nazwisko</label>
          <div class="form-control form-control-static">
            <%= user.first_name %> <%= user.last_name %>
          </div>
        </div>

        <div class="form-group">
          <label for="email">Adres E-mail</label>
          <input type="email" id="email" name="email" class="form-control" value="<%= user.email %>" required>
        </div>

        <div class="form-grid-2">
          <div class="form-group">
            <label for="phone">Telefon</label>
            <input type="text" id="phone" name="phone" class="form-control" value="<%= user.phone || '' %>" placeholder="+48 ...">
          </div>
          <div class="form-group">
            <label>Dział</label>
            <div class="form-control form-control-static">
              <i class="fa-solid fa-building icon-gap-right text-primary"></i>
              <%= user.department_name || 'Brak przypisania' %>
            </div>
          </div>
        </div>

        <div class="form-group">
          <label>Rola w systemie</label>
          <span class="status-badge text-capitalize"><%= user.role %></span>
        </div>

        <h4 class="dashboard-section-title mt-3">Zmiana hasła</h4>
        <p class="text-muted text-small mb-2">Wypełnij poniższe pola tylko, jeśli chcesz zmienić obecne hasło.</p>

        <div class="form-group">
          <label for="currentPassword">Aktualne hasło</label>
          <input type="password" id="currentPassword" name="currentPassword" class="form-control" placeholder="••••••••">
        </div>

        <div class="form-grid-2">
          <div class="form-group">
            <label for="newPassword">Nowe hasło</label>
            <input type="password" id="newPassword" name="newPassword" class="form-control" placeholder="Min. 6 znaków">
          </div>
          <div class="form-group">
            <label for="confirmPassword">Powtórz nowe hasło</label>
            <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" placeholder="••••••••">
          </div>
        </div>

        <div class="flex-between border-top pt-2 mt-3">
          <a href="/auth/logout" class="text-danger text-no-decoration font-medium">Wyloguj się</a>
          <button type="submit" class="btn btn-primary">Zapisz zmiany</button>
        </div>
      </form>
    </div>
  </div>
</main>
