<% 
  // Mocki do testowania UI profilu
  if (typeof error === 'undefined') { var error = null; } 
  if (typeof success === 'undefined') { var success = null; } 
%>

<main class="container" style="padding: 4rem 12.5%; min-height: 70vh">
  <div class="back-link">
    <a href="/"><i class="fa-solid fa-arrow-left"></i> Powrót do pulpitu</a>
  </div>

  <div class="auth-section" style="min-height: auto; padding-top: 2rem">
    <div class="auth-card" style="max-width: 700px; text-align: left">
      <h2>Mój <span class="highlight">Profil</span></h2>
      <p>Zaktualizuj swoje dane kontaktowe lub zmień hasło dostępu.</p>

      <% if (error) { %>
        <div class="alert"><i class="fa-solid fa-triangle-exclamation"></i> <%= error %></div>
      <% } %>

      <% if (success) { %>
        <div class="alert" style="background: rgba(34, 197, 94, 0.15); color: #22c55e; border-color: rgba(34, 197, 94, 0.3);">
          <i class="fa-solid fa-check"></i> <%= success %>
        </div>
      <% } %>

      <form action="/users/profile" method="POST" style="margin-top: 2rem">
        <!-- Sekcja: Dane podstawowe -->
        <h4 class="dashboard-section-title" style="font-size: 1.1rem; margin-bottom: 1rem;">Dane kontaktowe</h4>
        
        <div class="form-group">
          <label>Imię i Nazwisko</label>
          <div
            class="form-control"
            style="background: rgba(255, 255, 255, 0.05); cursor: default"
          >
            <%= user.first_name %> <%= user.last_name %>
          </div>
        </div>

        <div class="form-group">
          <label for="email">Adres E-mail</label>
          <input type="email" id="email" name="email" class="form-control" value="<%= user.email %>" required>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem">
          <div class="form-group">
            <label for="phone">Telefon</label>
            <input type="text" id="phone" name="phone" class="form-control" value="<%= user.phone || '' %>" placeholder="+48 ...">
          </div>
          <div class="form-group">
            <label>Dział</label>
            <div
              class="form-control"
              style="background: rgba(255, 255, 255, 0.05); cursor: default"
            >
              <i
                class="fa-solid fa-building"
                style="margin-right: 8px; color: var(--primary-color)"
              ></i>
              <%= user.department_name || 'Brak przypisania' %>
            </div>
          </div>
        </div>

        <div class="form-group">
          <label>Rola w systemie</label>
          <span class="status-badge" style="text-transform: capitalize"><%= user.role %></span>
        </div>

        <!-- Sekcja: Zmiana hasła -->
        <h4 class="dashboard-section-title" style="font-size: 1.1rem; margin-top: 2.5rem; margin-bottom: 1rem;">Zmiana hasła</h4>
        <p class="text-muted" style="font-size: 0.85rem; margin-bottom: 1.5rem;">Wypełnij poniższe pola tylko, jeśli chcesz zmienić obecne hasło.</p>

        <div class="form-group">
          <label for="currentPassword">Aktualne hasło</label>
          <input type="password" id="currentPassword" name="currentPassword" class="form-control" placeholder="••••••••">
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem">
          <div class="form-group">
            <label for="newPassword">Nowe hasło</label>
            <input type="password" id="newPassword" name="newPassword" class="form-control" placeholder="Min. 6 znaków">
          </div>
          <div class="form-group">
            <label for="confirmPassword">Powtórz nowe hasło</label>
            <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" placeholder="••••••••">
          </div>
        </div>

        <div
          style="
            margin-top: 3rem;
            border-top: 1px solid var(--border-color);
            padding-top: 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
          "
        >
          <a
            href="/logout"
            style="color: #ef4444; text-decoration: none; font-size: 0.9rem; font-weight: 600;"
            >Wyloguj się</a
          >
          <button type="submit" class="btn btn-primary">Zapisz zmiany</button>
        </div>
      </form>
    </div>
  </div>
</main>
