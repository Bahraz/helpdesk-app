<main class="auth-section">
  <div class="auth-card card-medium">
    <h2 class="text-center mb-1_5">
      Edycja pracownika #<%= editedUser.id %>
    </h2>

    <p class="text-center mb-2">
      Zmień dane pracownika, przypisz mu nową rolę lub zablokuj dostęp do
      systemu.
    </p>

    <% if (typeof error !== "undefined" && error) { %>
      <div class="alert alert-danger text-center mb-1">
        <i class="fa-solid fa-circle-exclamation"></i>
        <%= error %>
      </div>
    <% } %>

    <form action="/users/edit/<%= editedUser.id %>" method="POST">
      <div class="form-grid-2">
        <div class="form-group">
          <label for="firstName">Imię</label>
          <input
            id="firstName"
            name="firstName"
            type="text"
            class="form-control"
            required
            value="<%= editedUser.first_name || '' %>"
          />
        </div>

        <div class="form-group">
          <label for="lastName">Nazwisko</label>
          <input
            id="lastName"
            name="lastName"
            type="text"
            class="form-control"
            required
            value="<%= editedUser.last_name || '' %>"
          />
        </div>
      </div>

      <div class="form-group">
        <label for="email">Adres E-mail</label>
        <input
          id="email"
          name="email"
          type="email"
          class="form-control"
          required
          value="<%= editedUser.email || '' %>"
        />
      </div>

      <div class="form-grid-3">
        <div class="form-group">
          <label for="departmentId">Dział</label>
          <select
            id="departmentId"
            name="departmentId"
            class="form-control select-default"
          >
            <option value="">-- Brak działu --</option>

            <% departments.forEach(function(department) { %>
              <option
                value="<%= department.id %>"
                <%= String(editedUser.department_id || "") === String(department.id) ? "selected" : "" %>
              >
                <%= department.name %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label for="roleId">Rola</label>
          <select
            id="roleId"
            name="roleId"
            class="form-control select-default"
            required
          >
            <option value="">-- Wybierz rolę --</option>

            <% roles.forEach(function(role) { %>
              <option
                value="<%= role.id %>"
                <%= String(editedUser.role_id || "") === String(role.id) ? "selected" : "" %>
              >
                <%= role.name %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label for="isActive">Status</label>
          <select
            id="isActive"
            name="isActive"
            class="form-control select-default"
            required
          >
            <option value="1" <%= Number(editedUser.is_active) === 1 ? "selected" : "" %>>
              Aktywny
            </option>

            <option value="0" <%= Number(editedUser.is_active) === 0 ? "selected" : "" %>>
              Zablokowany
            </option>
          </select>
        </div>
      </div>

      <div class="flex-gap mt-2">
        <a
          href="/users/reset-password/<%= editedUser.id %>"
          class="btn btn-outline btn-outline-warning flex-1 text-center"
        >
          <i class="fa-solid fa-key"></i> Zresetuj hasło
        </a>

        <button
          type="submit"
          class="btn btn-primary flex-1 btn-sm"
        >
          Zapisz zmiany
          <i class="fa-solid fa-check icon-gap-left"></i>
        </button>
      </div>

      <div class="text-center mt-1">
        <a href="/users" class="text-link-muted">
          <i class="fa-solid fa-arrow-left"></i> Anuluj i wróć do profilu
        </a>
      </div>
    </form>
  </div>
</main>