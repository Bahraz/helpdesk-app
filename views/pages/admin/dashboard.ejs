
<main class="page-layout">
  <h3 class="dashboard-section-title">
    Nowe zgłoszenia (Oczekujące)
    <span class="badge badge-danger"><%= unassignedTickets.length %></span>
  </h3>
  
  <div class="ticket-grid">
    <% if (unassignedTickets.length > 0) { %>
      <% unassignedTickets.forEach(ticket => { %>
        <%- include('../../partials/ticket-card', { ticket: ticket, type: 'pending' }) %>
      <% }) %>
    <% } else { %>
      <p class="text-muted">Brak nowych zgłoszeń w systemie.</p>
      <% } %>
  </div>
</main>
