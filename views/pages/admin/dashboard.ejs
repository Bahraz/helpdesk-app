<%
  // MOCK DANYCH: Tabela ticket (na podstawie README.md)
  // id, tytuł, opis, priorytet, status, przypisany_admin_id, twórca_id, czas_założenia, czas_aktualizacji
  const currentAdminId = 1; // Załóżmy, że zalogowany admin ma ID = 1 w bazie

  const mockTickets = [
    {
      id: 101,
      tytul: "Brak dostępu do serwera plików",
      opis: "Po aktualizacji systemu Windows nie mogę połączyć się z dyskiem Z.",
      priorytet: "Wysoki",
      status: "Nowe",
      przypisany_admin_id: null,
      tworca_nazwa: "Anna Kowalska (HR)",
      czas_zalozenia: "09:15, Dziś"
    },
    {
      id: 102,
      tytul: "Wymiana tonera w drukarce",
      opis: "Drukarka na 2 piętrze zgłasza niski poziom czarnego tonera.",
      priorytet: "Niski",
      status: "Nowe",
      przypisany_admin_id: null,
      tworca_nazwa: "Piotr Nowak (Księgowość)",
      czas_zalozenia: "08:30, Dziś"
    },
    {
      id: 100,
      tytul: "Niedziałający monitor",
      opis: "Brak zasilania w jednym z monitorów co utrudnia i spowalnia pracę.",
      priorytet: "Średni",
      status: "Nowe",
      przypisany_admin_id: null,
      tworca_nazwa: "Piotr Nowak (Księgowość)",
      czas_zalozenia: "08:55, Dziś"
    },
    {
      id: 98,
      tytul: "Konfiguracja konta VPN",
      opis: "Proszę o utworzenie dostępu VPN dla nowego pracownika.",
      priorytet: "Średni",
      status: "W toku",
      przypisany_admin_id: currentAdminId,
      tworca_nazwa: "Jan Kaczmarek (Sprzedaż)",
      czas_zalozenia: "15:40, Wczoraj"
    }
  ];

  // EJS na bieżąco dzieli tickety na dwie tablice
  const unassignedTickets = mockTickets.filter(t => t.przypisany_admin_id === null);
  const myTickets = mockTickets.filter(t => t.przypisany_admin_id === currentAdminId);
%>

<main style="padding: 4rem 12.5%; min-height: 80vh;">
  <!-- SEKCJA 1: Nowe, nieprzypisane tickety -->
  <h3 class="dashboard-section-title">
    Nowe zgłoszenia (Oczekujące)
    <span class="badge" style="margin-bottom: 0; background: rgba(239, 68, 68, 0.1); color: #ef4444; border-color: #ef4444;"><%= unassignedTickets.length %></span>
  </h3>
  
  <div class="ticket-grid">
    <% if (unassignedTickets.length > 0) { %>
      <% unassignedTickets.forEach(ticket => { %>
        <% 
          let priorityClass = 'priority-low';
          if (ticket.priorytet === 'Wysoki') priorityClass = 'priority-high';
          else if (ticket.priorytet === 'Średni') priorityClass = 'priority-medium';
        %>
        <div class="ticket-card">
          <div class="ticket-meta">
            <span class="ticket-id">#T-<%= ticket.id %></span>
            <span class="ticket-time"><i class="fa-regular fa-clock"></i> <%= ticket.czas_zalozenia %></span>
          </div>
          <div class="ticket-title"><%= ticket.tytul %></div>
          <div class="ticket-desc"><%= ticket.opis %></div>
          
          <div style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1rem;">
            <i class="fa-solid fa-user"></i> <%= ticket.tworca_nazwa %>
          </div>

          <div class="ticket-footer" style="margin-top: auto;">
            <span class="priority-badge <%= priorityClass %>"><i class="fa-solid fa-flag"></i> <%= ticket.priorytet %></span>
            <a href="/tickets/detail" class="btn btn-outline" style="padding: 0.4rem 1rem; font-size: 0.85rem;">Odpowiedz</a>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <p style="color: var(--text-muted);">Brak nowych zgłoszeń w systemie.</p>
    <% } %>
  </div>

  <!-- SEKCJA 2: Tickety przypisane do admina -->
  <h3 class="dashboard-section-title">
    Twoje przejęte zgłoszenia
    <span class="badge" style="margin-bottom: 0;"><%= myTickets.length %></span>
  </h3>
  
  <div class="ticket-grid">
    <% if (myTickets.length > 0) { %>
      <% myTickets.forEach(ticket => { %>
        <div class="ticket-card" style="border-color: var(--primary-glow);">
          <div class="ticket-meta">
            <span class="ticket-id">#T-<%= ticket.id %></span>
            <span class="ticket-time"><i class="fa-regular fa-clock"></i> <%= ticket.czas_zalozenia %></span>
          </div>
          <div class="ticket-title"><%= ticket.tytul %></div>
          <div class="ticket-desc"><%= ticket.opis %></div>
          
          <div style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1rem;">
            <i class="fa-solid fa-user"></i> <%= ticket.tworca_nazwa %>
          </div>

          <div class="ticket-footer" style="margin-top: auto;">
            <span class="status-badge"><i class="fa-solid fa-spinner"></i> <%= ticket.status %></span>
            <a href="/tickets/detail" class="btn btn-primary" style="padding: 0.4rem 1rem; font-size: 0.85rem;">Odpowiedz</a>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <p style="color: var(--text-muted);">Obecnie nie masz przypisanych do siebie żadnych zgłoszeń.</p>
    <% } %>
  </div>
</main>
