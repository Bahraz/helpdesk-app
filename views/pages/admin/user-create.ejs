<main class="auth-section">
  <div class="auth-card" style="max-width: 600px; text-align: left">
    <h2 style="text-align: center; margin-bottom: 1.5rem">
      Utwórz konto pracownika
    </h2>
    <p style="text-align: center; margin-bottom: 2rem">
      Wygenerowane hasło jednorazowe zostanie wyświetlone na ekranie po
      poprawnym utworzeniu konta.
    </p>

    <form action="/admin/user/new" method="POST">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem">
        <div class="form-group">
          <label>Imię</label>
          <input type="text" class="form-control" required placeholder="Jan" />
        </div>
        <div class="form-group">
          <label>Nazwisko</label>
          <input
            type="text"
            class="form-control"
            required
            placeholder="Kowalski"
          />
        </div>
      </div>

      <div class="form-group">
        <label>Adres E-mail</label>
        <input
          type="email"
          class="form-control"
          required
          placeholder="j.kowalski@firma.pl"
        />
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem">
        <div class="form-group">
          <label>Dział</label>
          <input
            type="text"
            class="form-control"
            required
            placeholder="np. HR, Księgowość"
          />
        </div>
        <div class="form-group">
          <label>Rola w systemie</label>
          <select class="form-control" style="appearance: auto">
            <option value="user">Użytkownik</option>
            <option value="admin">Administrator</option>
          </select>
        </div>
      </div>

      <div class="form-group" style="margin-top: 2rem">
        <button type="submit" class="btn btn-primary" style="width: 100%">
          Zarejestruj i wygeneruj hasło
          <i
            class="fa-solid fa-wand-magic-sparkles"
            style="margin-left: 6px"
          ></i>
        </button>
      </div>
      <div style="text-align: center">
        <a
          href="/users"
          style="
            color: var(--text-muted);
            text-decoration: none;
            font-size: 0.9rem;
          "
          ><i class="fa-solid fa-arrow-left"></i> Anuluj i wróć do profilu</a
        >
      </div>
    </form>
  </div>
</main>
