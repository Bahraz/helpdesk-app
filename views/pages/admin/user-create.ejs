<main class="auth-section">
  <div class="auth-card card-medium">
    <h2 class="text-center mb-1_5">
      Utwórz konto pracownika
    </h2>

    <p class="text-center mb-2">
      Wygenerowane hasło jednorazowe zostanie wyświetlone na ekranie po
      poprawnym utworzeniu konta.
    </p>

    <% if (typeof error !== "undefined" && error) { %>
      <div class="alert alert-danger text-center mb-1">
        <i class="fa-solid fa-circle-exclamation"></i>
        <%= error %>
      </div>
    <% } %>

    <form action="/users/new" method="POST">
      <div class="form-grid-2">
        <div class="form-group">
          <label for="firstName">Imię</label>
          <input
            id="firstName"
            name="firstName"
            type="text"
            class="form-control"
            required
            placeholder="Jan"
            value="<%= formData?.firstName || '' %>"
          />
        </div>

        <div class="form-group">
          <label for="lastName">Nazwisko</label>
          <input
            id="lastName"
            name="lastName"
            type="text"
            class="form-control"
            required
            placeholder="Kowalski"
            value="<%= formData?.lastName || '' %>"
          />
        </div>
      </div>

      <div class="form-group">
        <label for="email">Adres E-mail</label>
        <input
          id="email"
          name="email"
          type="email"
          class="form-control"
          required
          placeholder="j.kowalski@firma.pl"
          value="<%= formData?.email || '' %>"
        />
      </div>

      <div class="form-grid-2">
        <div class="form-group">
          <label for="departmentId">Dział</label>
          <select
            id="departmentId"
            name="departmentId"
            class="form-control select-default"
          >
            <option value="">-- Wybierz dział --</option>

            <% departments.forEach(function(department) { %>
              <option
                value="<%= department.id %>"
                <%= String(formData?.departmentId || "") === String(department.id) ? "selected" : "" %>
              >
                <%= department.name %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label for="roleId">Rola w systemie</label>
          <select
            id="roleId"
            name="roleId"
            required
            class="form-control select-default"
          >
            <option value="">-- Wybierz rolę --</option>

            <% roles.forEach(function(role) { %>
              <option
                value="<%= role.id %>"
                <%= String(formData?.roleId || "") === String(role.id) ? "selected" : "" %>
              >
                <%= role.name %>
              </option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="form-group mt-2">
        <button type="submit" class="btn btn-primary btn-wide">
          Zarejestruj i wygeneruj hasło
          <i class="fa-solid fa-wand-magic-sparkles icon-gap-left"></i>
        </button>
      </div>

      <div class="text-center mt-1">
        <a href="/users" class="text-link-muted">
          <i class="fa-solid fa-arrow-left"></i> Anuluj i wróć do profilu
        </a>
      </div>
    </form>
  </div>
</main>