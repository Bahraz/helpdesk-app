<%
  const mockTickets = [
    { id: 101, tytul: "Brak dostępu do serwera plików", opis: "Po aktualizacji systemu Windows nie mogę połączyć się z dyskiem Z.", priorytet: "Wysoki", tworca_nazwa: "Anna Kowalska", czas_zalozenia: "09:15, Dziś" },
    { id: 102, tytul: "Wymiana tonera w drukarce", opis: "Drukarka na 2 piętrze zgłasza niski poziom czarnego tonera.", priorytet: "Niski", tworca_nazwa: "Piotr Nowak", czas_zalozenia: "08:30, Dziś" },
    { id: 100, tytul: "Niedziałający monitor", opis: "Brak zasilania w jednym z monitorów co utrudnia i spowalnia pracę.", priorytet: "Średni", tworca_nazwa: "Kamil Wiśniewski", czas_zalozenia: "Wczoraj" }
  ];
%>
<main style="padding: 4rem 12.5%; min-height: 80vh;">
  <h2 style="margin-bottom: 2rem;">Oczekujące zgłoszenia</h2>
  <div class="ticket-grid">
    <% mockTickets.forEach(ticket => { %>
      <% 
        let priorityClass = 'priority-low';
        if (ticket.priorytet === 'Wysoki') priorityClass = 'priority-high';
        else if (ticket.priorytet === 'Średni') priorityClass = 'priority-medium';
      %>
      <div class="ticket-card">
        <div class="ticket-meta">
          <span class="ticket-id">#T-<%= ticket.id %></span>
          <span class="ticket-time"><i class="fa-regular fa-clock"></i> <%= ticket.czas_zalozenia %></span>
        </div>
        <div class="ticket-title"><%= ticket.tytul %></div>
        <div class="ticket-desc"><%= ticket.opis %></div>
        <div style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1rem;"><i class="fa-solid fa-user"></i> <%= ticket.tworca_nazwa %></div>
        <div class="ticket-footer" style="margin-top: auto;">
          <span class="priority-badge <%= priorityClass %>"><i class="fa-solid fa-flag"></i> <%= ticket.priorytet %></span>
          <a href="/tickets/detail" class="btn btn-outline" style="padding: 0.4rem 1rem; font-size: 0.85rem;">Odpowiedz</a>
        </div>
      </div>
    <% }) %>
  </div>
</main>