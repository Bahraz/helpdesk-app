<main class="auth-section">
  <div class="auth-card" style="max-width: 600px; text-align: center">
    <div
      style="
        font-size: 3.5rem;
        color: #22c55e;
        margin-bottom: 1rem;
        filter: drop-shadow(0 0 15px rgba(34, 197, 94, 0.4));
      "
    >
      <i class="fa-solid fa-user-check"></i>
    </div>
    <h2 style="margin-bottom: 1rem">Konto zostało utworzone</h2>
    <p style="color: var(--text-muted); margin-bottom: 2rem; line-height: 1.6">
      Nowy pracownik został pomyślnie dodany do systemu. Zostało dla niego
      wygenerowane hasło jednorazowe, a status wymuszenia zmiany hasła został
      aktywowany. Skopiuj poniższe hasło i przekaż je pracownikowi.
    </p>

    <div
      style="
        background: rgba(0, 0, 0, 0.3);
        border: 1px dashed var(--border-color);
        padding: 1.5rem;
        border-radius: 8px;
        margin-bottom: 2rem;
      "
    >
      <span
        style="
          font-size: 0.9rem;
          color: var(--text-muted);
          display: block;
          margin-bottom: 0.5rem;
        "
        >Wygenerowane hasło dla użytkownika:</span
      >
      <strong
        style="
          font-size: 1.8rem;
          color: var(--text-main);
          letter-spacing: 3px;
          user-select: all;
        "
        >Start#123!</strong
      >
    </div>

    <a href="/profile" class="btn btn-primary" style="width: 100%">
      Wróć do zarządzania
      <i class="fa-solid fa-arrow-right" style="margin-left: 6px"></i>
    </a>
  </div>
</main>
