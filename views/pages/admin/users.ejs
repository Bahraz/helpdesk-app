<main style="padding: 4rem 12.5%; min-height: 80vh;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h2>Twój Profil Administracyjny</h2>
    <div class="flex-row">
      <a href="/users/profile" class="btn btn-outline"><i class="fa-solid fa-user"></i> Edytuj konto</a>
      <a href="/users/new" class="btn btn-primary"><i class="fa-solid fa-user-plus"></i> Utwórz nowe konto</a>
    </div>

  </div>

  <div class="ticket-detail-header">
    <form action="/users/profile" method="POST">
      <div class="flex-col">
        <div class="flex-row w-full">
          <div class="form-group w-full">
            <label>Imię</label>
            <input type="text" id="firstName" class="form-control"
              value="<%= typeof user !== 'undefined' ? user.firstName : '' %>" required>
          </div>
          <div class="form-group w-full">
            <label>Nazwisko</label>
            <input type="text" id="lastName" class="form-control"
              value="<%= typeof user !== 'undefined' ? user.lastName : '' %>" required>
          </div>
          <div class="form-group w-full">

            <label>Adres E-mail</label>
            <input type="email" id="email" class="form-control"
              value="<%= typeof user !== 'undefined' ? user.email : '' %>" required>
          </div>
          <div class="form-group w-full">
            <label>Telefon</label>
            <input type="text" id="phone" class="form-control"
              value="<%= typeof user !== 'undefined' ? user.phone : '' %>" placeholder="+48 ...">
          </div>
        </div>
      </div>
    </form>
  </div>

  <h3 style="margin-top: 3rem; margin-bottom: 1.5rem;">Zarządzanie Użytkownikami Firmy</h3>
  <div class="table-container">
    <table class="custom-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Pracownik</th>
          <th>Email</th>
          <th>Dział</th>
          <th>Rola</th>
          <th>Ostatnie logowanie</th>
          <th>Status</th>
          <th>Akcje</th>
        </tr>
      </thead>
      <tbody>
        <% const usersList=typeof users !=="undefined" ? users : []; %>

          <% if (usersList.length> 0) { %>
            <% usersList.forEach(u=> { %>
              <tr>
                <td style="color: var(--primary-color);">#<%= u.id %>
                </td>
                <td><strong>
                    <%= u.first_name %>
                      <%= u.last_name %>
                  </strong></td>
                <td>
                  <%= u.email %>
                </td>
                <td>
                  <%= u.department_name || "Brak działu" %>
                </td>
                <td>
                  <% if (u.role==="Admin" ) { %>
                    <span class="badge"
                      style="background: rgba(14, 165, 233, 0.1); color: var(--primary-color); border: none; margin: 0;">
                      <%= u.role %>
                    </span>
                    <% } else { %>
                      <span class="badge"
                        style="background: rgba(255,255,255,0.1); color: var(--text-main); border: none; margin: 0;">
                        <%= u.role || "Brak roli" %>
                      </span>
                      <% } %>
                </td>
                <td>
                  <% if (u.last_login_at) { %>
                    <%= u.last_login_at %>
                  <% } else { %>
                      <span class="text-muted">Brak logowania</span>
                  <% } %>

                </td>
                <td>
                  <% if (u.is_active) { %>
                    <span style="color: #22c55e;"><i class="fa-solid fa-circle-check"></i> Aktywny</span>
                    <% } else { %>
                      <span style="color: #ef4444;"><i class="fa-solid fa-circle-xmark"></i> Zablokowany</span>
                      <% } %>
                </td>
                <td>
                  <a href="/users/edit/<%= u.id %>" class="btn btn-outline"
                    style="padding: 0.2rem 0.6rem; font-size: 0.8rem;">
                    <i class="fa-solid fa-pen-to-square"></i> Edytuj
                  </a>
                </td>
              </tr>
              <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="7" style="text-align: center; padding: 2rem;">
                      Brak użytkowników do wyświetlenia.
                    </td>
                  </tr>
                  <% } %>
      </tbody>
    </table>
  </div>
</main>