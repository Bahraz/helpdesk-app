<main class="auth-section">
  <div class="auth-card" style="max-width: 600px; text-align: center">
    <div style="font-size: 3.5rem; color: #eab308; margin-bottom: 1rem; filter: drop-shadow(0 0 15px rgba(234, 179, 8, 0.4));">
      <i class="fa-solid fa-key"></i>
    </div>

    <h2 style="margin-bottom: 1rem">
      Hasło zresetowane
    </h2>

    <p style="color: var(--text-muted); margin-bottom: 2rem; line-height: 1.6;">
      Dla konta
      <strong>
        <%= editedUser.email %>
      </strong>
      wygenerowano nowe hasło tymczasowe.
      Użytkownik może zalogować się tym hasłem.
    </p>

    <div style="background: rgba(0, 0, 0, 0.3); border: 1px dashed var(--border-color); padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem;">
      <span style="font-size: 0.9rem; color: var(--text-muted); display: block; margin-bottom: 0.5rem;">
        Tymczasowe hasło:
      </span>

      <strong style="font-size: 1.8rem; color: var(--text-main); letter-spacing: 3px; user-select: all;">
        <%= temporaryPassword %>
      </strong>
    </div>

    <div style="display: flex; gap: 1rem;">
      <a href="/users/edit/<%= editedUser.id %>" class="btn btn-outline" style="flex: 1; text-align: center;">
        Wróć do edycji
      </a>

      <a href="/users" class="btn btn-primary" style="flex: 1; text-align: center;">
        Wróć do zarządzania
        <i class="fa-solid fa-arrow-right" style="margin-left: 6px"></i>
      </a>
    </div>
  </div>
</main>