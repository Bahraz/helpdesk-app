<main class="auth-section">
  <div class="auth-card card-small">
    <div class="icon-large icon-warning">
      <i class="fa-solid fa-key"></i>
    </div>

    <h2 class="mb-1">Hasło zresetowane</h2>

    <p class="text-muted mb-2 line-height">
      Dla konta
      <strong> <%= editedUser.email %> </strong>
      wygenerowano nowe hasło tymczasowe. Użytkownik może zalogować się tym
      hasłem.
    </p>

    <div class="box-dashed">
      <span class="text-muted text-small mb-half"> Tymczasowe hasło: </span>

      <strong class="result-password"> <%= temporaryPassword %> </strong>
    </div>

    <div class="flex-gap">
      <a
        href="/users/edit/<%= editedUser.id %>"
        class="btn btn-outline flex-1 text-center"
      >
        Wróć do edycji
      </a>

      <a href="/users" class="btn btn-primary btn-wide">
        Wróć do zarządzania
        <i class="fa-solid fa-arrow-right icon-gap-left"></i>
      </a>
    </div>
  </div>
</main>
