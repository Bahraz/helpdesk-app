<main class="auth-section">
  <div class="auth-card" style="max-width: 500px; text-align: center">
    <div
      style="
        font-size: 3.5rem;
        color: var(--primary-color);
        margin-bottom: 1rem;
        filter: drop-shadow(0 0 15px var(--primary-glow));
      "
    >
      <i class="fa-solid fa-right-from-bracket"></i>
    </div>
    <h2 style="margin-bottom: 1rem">Wylogowano pomyślnie</h2>
    <p style="color: var(--text-muted); margin-bottom: 2rem; line-height: 1.6">
      Zostałeś bezpiecznie wylogowany z systemu HelpDesk. Do zobaczenia wkrótce!
    </p>

    <a href="/auth/login" class="btn btn-primary" style="width: 100%">
      Zaloguj się ponownie
      <i
        class="fa-solid fa-arrow-right-to-bracket"
        style="margin-left: 6px"
      ></i>
    </a>
    <div style="margin-top: 1rem">
      <a
        href="/"
        style="
          color: var(--text-muted);
          text-decoration: none;
          font-size: 0.9rem;
        "
      >
        Wróć na stronę główną
      </a>
    </div>
  </div>
</main>
