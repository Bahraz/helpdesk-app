<%- include('../partials/header') %>

<div class="auth-container">
    <div class="auth-card auth-card-large">
        <div class="auth-header">
            <h2>Konto Firmowe</h2>
            <p>Utwórz profil, aby zgłaszać problemy techniczne.</p>
        </div>

        <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <form action="/auth/register" method="POST">
            <div class="form-row">
                <div class="form-group">
                    <label>Imię</label>
                    <input type="text" name="firstName" class="form-control" required>
                </div>
                <div class="form-group">
                    <label>Nazwisko</label>
                    <input type="text" name="lastName" class="form-control" required>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Firma / Organizacja</label>
                    <input type="text" name="company" class="form-control" required>
                </div>
                <div class="form-group">
                    <label>Dział</label>
                    <select name="department" class="form-control" required>
                        <option value="">Wybierz dział...</option>
                        <option value="IT">IT / Techniczny</option>
                        <option value="HR">Kadry (HR)</option>
                        <option value="Sales">Sprzedaż</option>
                        <option value="Management">Zarząd</option>
                        <option value="Other">Inny</option>
                    </select>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Stanowisko (Opcjonalnie)</label>
                    <input type="text" name="position" class="form-control">
                </div>
                <div class="form-group">
                    <label>Numer telefonu</label>
                    <input type="tel" name="phone" class="form-control">
                </div>
            </div>

            <hr class="auth-divider">

            <div class="form-group">
                <label>Służbowy adres e-mail</label>
                <input type="email" name="email" class="form-control" required>
            </div>
            
            <div class="form-group">
                <label>Hasło</label>
                <input type="password" name="password" class="form-control" required minlength="6">
            </div>

            <button type="submit" class="btn btn-primary btn-block">Zarejestruj profil firmowy</button>
        </form>
        <p class="auth-footer-text">
            Masz już konto? <a href="/auth/login">Zaloguj się</a>
        </p>
    </div>
</div>

<%- include('../partials/footer') %>